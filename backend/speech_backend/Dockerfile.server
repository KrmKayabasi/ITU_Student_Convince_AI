# Lightweight speech server container for OpenAI Realtime mode.
# The default server path no longer needs local CUDA/Whisper/Gemma/TTS models.

FROM python:3.11-slim

WORKDIR /workspace

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

COPY requirements_server.txt /workspace/requirements_server.txt
RUN pip install --no-cache-dir -r /workspace/requirements_server.txt

# Copy speech server source code and assets
COPY . /workspace/

EXPOSE 8002

# Start the FastAPI server using Uvicorn
CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8002"]
